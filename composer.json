{
    "name": "quorae/grid-bundle",
    "type": "symfony-bundle",
    "description": "Declarative attribute-driven listing/search/filter/sort/pagination framework for Symfony 7+ (Turbo Frame + Live Component dual mode).",
    "license": "MIT",
    "keywords": ["symfony", "symfony-ux", "grid", "listing", "datatable", "live-component", "turbo"],
    "authors": [{ "name": "Tristan Florin", "email": "tristan.florin@gmail.com" }],
    "require": {
        "php": ">=8.3",
        "symfony/config": "^7.0",
        "symfony/dependency-injection": "^7.0",
        "symfony/http-foundation": "^7.0",
        "symfony/http-kernel": "^7.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0 || ^12.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/security-bundle": "^7.0",
        "symfony/twig-bundle": "^7.0",
        "symfony/ux-twig-component": "^2.18 || ^3.0",
        "symfony/ux-live-component": "^2.18 || ^3.0",
        "phpstan/phpstan": "^2.1"
    },
    "suggest": {
        "symfony/ux-twig-component": "Turbo-Frame grid component (<twig:Grid:Grid>)",
        "symfony/ux-live-component": "Live-Component grid component (<twig:Grid:LiveGrid>) + bulk actions",
        "symfony/security-bundle": "Required only by the bulk-action subsystem"
    },
    "autoload": { "psr-4": { "Quorae\\GridBundle\\": "src/" } },
    "autoload-dev": { "psr-4": { "Quorae\\GridBundle\\Tests\\": "tests/" } },
    "config": { "sort-packages": true },
    "extra": { "symfony": { "require": "^7.0" } }
}
