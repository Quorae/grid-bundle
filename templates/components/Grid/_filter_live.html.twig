{#
 # Grid framework — rendu en mode Live Component.
 #
 # Ce partial est appelé en deux modes depuis _filter_bar.html.twig :
 #
 # Mode tokens (popoverMode = false, défaut) :
 #   Rend les .fb-token pour chaque filtre Pills/Select/Toggle actif.
 #   Chaque token "×" déclenche la LiveAction `setFilter` avec une valeur vide
 #   pour retirer le filtre.
 #   Gère le mode condensé +N (overflow tokens cachés, inline reveal).
 #   Rend le token DateRange résumé quand actif.
 #
 # Mode popover (popoverMode = true) :
 #   Rend le conteneur <div class="fb-pop"> vide — les items sont injectés
 #   dynamiquement par grid_filter_bar_controller.js depuis prefixesValue.
 #
 # Params :
 #   filters            : FilterDefinition[]
 #   view               : GridView
 #   popoverMode        : bool (défaut false)
 #   popoverId          : string (id du popover, requis si popoverMode = true)
 #   prefixMap          : array  (map propriété → {label, choices})
 #   maxVisible         : int|null (null = show all, 3 = condensed mode)
 #   activeTokenCount   : int (total tokens including DateRange)
 #   dateRangeTokenData : object|null ({ label, propertyName, fromFormatted, toFormatted, fromInputId })
 #
 # LiveAction `setFilter` attendue sur le composant Live :
 #   #[LiveAction]
 #   public function setFilter(#[LiveArg] string $property, #[LiveArg] string $value): void
 #
 # LiveAction `clearFilters` attendue sur le composant Live :
 #   #[LiveAction]
 #   public function clearFilters(): void
 #}

{% from '@QuoraeGrid/components/Grid/_macros.html.twig' import close_icon %}
{% set popoverMode = popoverMode ?? false %}
{% set maxVisible = maxVisible ?? null %}
{% set activeTokenCount = activeTokenCount ?? 0 %}
{% set dateRangeTokenData = dateRangeTokenData ?? null %}

{% if not popoverMode %}
    {# ============================================================
     # Mode tokens : rend les chips des filtres actifs (Live)
     # ============================================================ #}
    {% set tokenIndex = 0 %}

    {% for filter in filters %}
        {% set filterType = filter.type.value ?? filter.type %}
        {% set rawCurrent = attribute(view.filter, filter.propertyName) %}
        {% set current = rawCurrent is not null and rawCurrent.value is defined ? rawCurrent.value : rawCurrent %}
        {% set normalizedCurrent = current is same as(false) ? '0' : current %}
        {% set hasValue = current is same as(false) or (current is not null and current != '') %}

        {# Select filters: rendered as visible <select> in _filter_bar, no token needed #}

        {% if filterType == 'pills' %}
            {% if hasValue %}
                {% set choiceLabel = filter.choices[normalizedCurrent] ?? normalizedCurrent %}
                {% set isOverflow = maxVisible is not null and tokenIndex >= maxVisible %}

                <span class="fb-token{% if isOverflow %} fb-token--overflow{% endif %}" role="status" aria-label="{{ filter.label }}: {{ choiceLabel }}">
                    <span class="fb-token__key">{{ filter.label }}</span>
                    <span class="fb-token__sep" aria-hidden="true">·</span>
                    <span class="fb-token__val{% if not (filter.valueMonospace ?? false) %} prose{% endif %}">{{ choiceLabel }}</span>
                    <button type="button"
                            class="fb-token__remove"
                            aria-label="Retirer le filtre {{ filter.label }}"
                            data-action="live#action:prevent"
                            data-live-action-param="setFilter"
                            data-live-property-param="{{ filter.propertyName }}"
                            data-live-value-param="">
                        {{ close_icon() }}
                    </button>
                </span>
                {% set tokenIndex = tokenIndex + 1 %}
            {% endif %}

        {% elseif filterType == 'toggle' %}
            {% if current %}
                {% set isOverflow = maxVisible is not null and tokenIndex >= maxVisible %}

                <span class="fb-token{% if isOverflow %} fb-token--overflow{% endif %}" role="status" aria-label="{{ filter.label }}: actif">
                    <span class="fb-token__check" aria-hidden="true">✓</span>
                    <span class="fb-token__val prose">{{ filter.label }}</span>
                    <button type="button"
                            class="fb-token__remove"
                            aria-label="Désactiver {{ filter.label }}"
                            data-action="live#action:prevent"
                            data-live-action-param="setFilter"
                            data-live-property-param="{{ filter.propertyName }}"
                            data-live-value-param="">
                        {{ close_icon() }}
                    </button>
                </span>
                {% set tokenIndex = tokenIndex + 1 %}
            {% endif %}
        {% endif %}
    {% endfor %}

    {# ── DateRange token résumé (read-only, dans la barre) ── #}
    {% if dateRangeTokenData is not null %}
        {% set isOverflow = maxVisible is not null and tokenIndex >= maxVisible %}

        <span class="fb-token fb-token--daterange{% if isOverflow %} fb-token--overflow{% endif %}"
              role="status"
              aria-label="{{ dateRangeTokenData.label }}: {{ dateRangeTokenData.fromFormatted }} → {{ dateRangeTokenData.toFormatted }}"
              title="{{ dateRangeTokenData.label }} : {{ dateRangeTokenData.fromFormatted }} → {{ dateRangeTokenData.toFormatted }}"
              data-action="click->grid-filter-bar#focusDateInput"
              data-date-input-id="{{ dateRangeTokenData.fromInputId }}">
            <span class="fb-token__key">{{ dateRangeTokenData.label }}</span>
            <span class="fb-token__sep" aria-hidden="true">·</span>
            <span class="fb-token__val">{{ dateRangeTokenData.fromFormatted }}</span>
            <span class="fb-token__arrow" aria-hidden="true">→</span>
            <span class="fb-token__val">{{ dateRangeTokenData.toFormatted }}</span>
            <button type="button"
                    class="fb-token__remove"
                    aria-label="Retirer le filtre {{ dateRangeTokenData.label }}"
                    data-action="click->grid-filter-bar#clearDateRange:stop"
                    data-date-property="{{ dateRangeTokenData.propertyName }}">
                {{ close_icon() }}
            </button>
        </span>
        {% set tokenIndex = tokenIndex + 1 %}
    {% endif %}

    {# ── Chip +N (mode condensé) ── #}
    {% if maxVisible is not null and activeTokenCount > maxVisible %}
        <button type="button"
                class="fb-token fb-token--more"
                aria-expanded="false"
                aria-label="{{ activeTokenCount - maxVisible }} filtres masqués"
                data-action="click->grid-filter-bar#toggleOverflow"
                data-live-ignore>
            +{{ activeTokenCount - maxVisible }}
        </button>
    {% endif %}

{% else %}
    {# ============================================================
     # Mode popover : conteneur vide, rempli dynamiquement par JS
     # depuis prefixesValue (évite la duplication statique/dynamique)
     # ============================================================ #}
    <div id="{{ popoverId }}"
         class="fb-pop"
         role="listbox"
         aria-label="Filtres disponibles"
         hidden
         data-live-ignore
         {{ stimulus_target('grid-filter-bar', 'popover') }}
         data-action="keydown->grid-filter-bar#onPopoverKeydown">
    </div>
{% endif %}
